<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>مقلة النصر</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Tahoma, Arial, sans-serif;
}

body{
background:#f5f1e8;
color:#333;
}

header{
background:#6b4423;
color:white;
text-align:center;
padding:40px 20px;
}

header h1{
font-size:48px;
margin-bottom:10px;
}

.hero{
text-align:center;
padding:40px 20px;
background:white;
}

.hero h2{
color:#6b4423;
margin-bottom:10px;
}

.info{
background:#fff;
padding:20px;
text-align:center;
font-size:18px;
}

.whatsapp{
display:inline-block;
margin-top:15px;
padding:12px 25px;
background:#25D366;
color:white;
text-decoration:none;
border-radius:8px;
font-size:18px;
}

.products{
padding:40px 20px;
}

.products h2{
text-align:center;
margin-bottom:30px;
color:#6b4423;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
max-width:1200px;
margin:auto;
}

.card{
background:white;
padding:20px;
border-radius:12px;
box-shadow:0 2px 10px rgba(0,0,0,.1);
text-align:center;
}

.card h3{
margin-bottom:10px;
color:#6b4423;
}

.price{
font-size:22px;
font-weight:bold;
color:#d35400;
}

footer{
background:#222;
color:white;
text-align:center;
padding:20px;
margin-top:40px;
}
</style>
</head>

<body>

